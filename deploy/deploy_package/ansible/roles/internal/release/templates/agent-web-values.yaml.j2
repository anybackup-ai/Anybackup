replicaCount: 2

image:
  repository: "{{ (v9_services_image_registry | length > 0) | ternary(v9_services_image_registry ~ '/', '') }}svc/agent-web"
  tag: "{{ v9_services_image_tag }}"
  pullPolicy: IfNotPresent

service:
  type: ClusterIP
  port: 80
  nodePort: null

authService:
  upstream: "http://api-gateway-service-traefik.{{ deployment_namespace }}.svc.cluster.local"

conversationService:
  upstream: "http://api-gateway-service-traefik.{{ deployment_namespace }}.svc.cluster.local"

ingress:
  enabled: false

probes:
  path: /healthz
