{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.local/decision-agent-ag-ui-message.schema.json",
  "title": "Decision Agent Markdown Response Message",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "event_type",
    "occurred_at",
    "source_service",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "event_type": {
      "const": "decision_agent.session.ag_ui_event"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_service": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "conversation_id",
        "turn_id",
        "message_id",
        "content",
        "sequence",
        "ag_ui"
      ],
      "properties": {
        "conversation_id": {
          "type": "string",
          "minLength": 1
        },
        "turn_id": {
          "type": "string",
          "minLength": 1
        },
        "message_id": {
          "type": "string",
          "minLength": 1
        },
        "content": {
          "type": "string",
          "minLength": 1
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "ag_ui": {
          "type": "string",
          "minLength": 1,
          "description": "User-visible Markdown text."
        }
      }
    }
  }
}
